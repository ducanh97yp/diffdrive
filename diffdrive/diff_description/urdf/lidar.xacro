<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" >

    <!-- Switched Livox Mid-360 -> Ouster OS1 (2026-07-11, LIO-SAM migration) - the
         customer directed a full SLAM stack replacement (FAST-LIO -> LIO-SAM) and
         lidar swap (Mid-360 -> OS1) together. OS1's vertical FOV is symmetric
         (+-22.5deg, 45deg total) unlike Mid-360's asymmetric -7~52deg, so - unlike
         every earlier lidar swap in this repo's history - no downward-biased-FOV
         trick (physical flip or negated native angle range) is needed at all - a
         level, upright mount already points half the beams up and half down.
         real OS1 dimensions - 85mm dia cylinder, 73.5mm tall, ~484g.
         N_SCAN=32 (a real OS1-32 variant) x Horizon_SCAN=512 (a real Ouster column
         count, not an arbitrary simulation-only number - keeps this config
         meaningful when transitioning to real ouster-ros hardware later).
         update_rate kept at 5Hz (half the real 10Hz default) for the same GPU-less
         raycasting load reason established for Mid-360 (32*512=16384 rays/scan,
         under 2x the old 24*360=8640 - should be fine on the same hardware that
         handled Mid-360's load; raise toward 10Hz if run on a GPU-equipped machine).

         Mount height 0.15 (chassis top clearance 0.107m) - re-derived empirically
         for OS1 the same way as Mid-360's - OS1's shallowest downward angle is only
         -22.5deg vs Mid-360's -52deg, so a much lower mount already clears most of
         the chassis, but a self-hit cluster still exists at this height (range
         0.24-0.50m, well short of the shortest real returns starting ~0.6m) -
         confirmed via direct point-cloud inspection and handled with a self-filter
         box in gz_lidar_to_ouster.cpp (see that file's comment for the numbers),
         same approach as the Mid-360 adapter. Raising the mount further would
         shrink the self-hit zone but was not necessary since the filter box already
         cleanly separates it from legitimate returns with margin to spare. -->
    <joint name="laser_joint" type="fixed">
        <parent link="chassis"/>
        <child link="laser_frame"/>
        <origin xyz="0.1697 0 0.15" rpy="0 0 0"/>
    </joint>

    <!-- Kich thuoc Ouster OS1 that - hinh tru phi85mm x cao 73.5mm, nang 484g. -->
    <link name="laser_frame">
        <visual>
            <geometry>
                <cylinder radius="0.0425" length="0.0735"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.0425" length="0.0735"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.484" length="0.0735" radius="0.0425">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>



    <gazebo reference="laser_frame">
        <material>Gazebo/Black</material>

        <!-- Ouster OS1 approximate config - FOV 360(H) x 45(V, +-22.5 deg symmetric),
             range 0.1-40m (real OS1 min range is closer to 0.3-0.5m depending on
             reflectivity; kept at 0.1 to match the rest of this repo's range
             convention). Gazebo's gpu_lidar is a fixed angular ray-cast grid, unlike
             OS1's real rotating-mirror-per-channel mechanism, so this is still only
             an approximation of the FOV shape, not the real scan mechanics - same
             caveat as every other simulated lidar in this repo. -->
        <sensor name="laser" type="gpu_lidar">
            <pose> 0 0 0 0 0 0 </pose>
            <topic>scan</topic>
            <gz_frame_id>laser_frame</gz_frame_id>
            <visualize>true</visualize>
            <always_on>true</always_on>
            <update_rate>5</update_rate>
            <lidar>
                <scan>
                    <horizontal>
                        <samples>512</samples>
                        <resolution>1</resolution>
                        <min_angle>-3.141592653589793</min_angle>
                        <max_angle>3.141592653589793</max_angle>
                    </horizontal>
                    <vertical>
                        <samples>32</samples>
                        <resolution>1</resolution>
                        <min_angle>-0.39269908169872414</min_angle>
                        <max_angle>0.39269908169872414</max_angle>
                    </vertical>
                </scan>
                <range>
                    <min>0.1</min>
                    <max>40</max>
                    <resolution>0.02</resolution>
                </range>
            </lidar>
        </sensor>
    </gazebo>

    <!-- Separate industrial-grade IMU (e.g. Xsens MTi-3 / VectorNav VN-100 class),
         no longer bundled inside the lidar housing like the Mid-360's integrated
         IMU - mounted directly on the chassis instead. Noise floors below are
         representative of factory-calibrated industrial MEMS (roughly 10-50x lower
         than the previous consumer-grade approximation) - angular_velocity stddev
         0.0003 -> 0.00003 rad/s, linear_acceleration stddev 0.017 -> 0.0015 m/s^2.
         fast_lio's tightly-coupled IMU+lidar filter uses this directly for its
         gravity/orientation estimate (see FAST_LIO_ROS2/src/IMU_Processing.hpp),
         which is what gives it correct ramp pitch tracking (<1 deg error measured)
         without the flat-ground pitch bias pure lidar-ICP approaches (MOLA) had. -->
    <joint name="imu_joint" type="fixed">
        <parent link="chassis"/>
        <child link="imu_link"/>
        <origin xyz="0.05 0 0.03" rpy="0 0 0"/>
    </joint>

    <link name="imu_link">
        <visual>
            <geometry>
                <box size="0.024 0.024 0.01"/>
            </geometry>
            <material name="red"/>
        </visual>
        <collision>
            <geometry>
                <box size="0.024 0.024 0.01"/>
            </geometry>
        </collision>
        <xacro:inertial_box mass="0.02" x="0.024" y="0.024" z="0.01">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <gazebo reference="imu_link">
        <material>Gazebo/Red</material>

        <sensor name="imu_sensor" type="imu">
            <pose>0 0 0 0 0 0</pose>
            <topic>imu</topic>
            <gz_frame_id>imu_link</gz_frame_id>
            <always_on>true</always_on>
            <update_rate>200</update_rate>
            <imu>
                <angular_velocity>
                    <x><noise type="gaussian"><mean>0</mean><stddev>0.00003</stddev></noise></x>
                    <y><noise type="gaussian"><mean>0</mean><stddev>0.00003</stddev></noise></y>
                    <z><noise type="gaussian"><mean>0</mean><stddev>0.00003</stddev></noise></z>
                </angular_velocity>
                <linear_acceleration>
                    <x><noise type="gaussian"><mean>0</mean><stddev>0.0015</stddev></noise></x>
                    <y><noise type="gaussian"><mean>0</mean><stddev>0.0015</stddev></noise></y>
                    <z><noise type="gaussian"><mean>0</mean><stddev>0.0015</stddev></noise></z>
                </linear_acceleration>
            </imu>
        </sensor>
    </gazebo>

    <!-- GPS/GNSS receiver for outdoor navigation - top-mounted for sky visibility.
         Sensor activation is world-plugin-driven (gz-sim-navsat-system), same
         pattern as the lidar/IMU above, so this block is inert and harmless in
         indoor worlds (house.world etc.) that don't load that plugin.
         update_rate matches navsat_transform_node's frequency
         (lio_sam_bringup/config/navsat_transform_outdoor.yaml). -->
    <joint name="gps_joint" type="fixed">
        <parent link="chassis"/>
        <child link="gps_link"/>
        <origin xyz="0 0 0.12" rpy="0 0 0"/>
    </joint>

    <link name="gps_link">
        <visual>
            <geometry>
                <box size="0.02 0.02 0.01"/>
            </geometry>
            <material name="red"/>
        </visual>
        <collision>
            <geometry>
                <box size="0.02 0.02 0.01"/>
            </geometry>
        </collision>
        <xacro:inertial_box mass="0.01" x="0.02" y="0.02" z="0.01">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <gazebo reference="gps_link">
        <material>Gazebo/Red</material>

        <sensor name="navsat_sensor" type="navsat">
            <pose>0 0 0 0 0 0</pose>
            <topic>navsat</topic>
            <gz_frame_id>gps_link</gz_frame_id>
            <always_on>true</always_on>
            <update_rate>10</update_rate>
            <navsat>
                <!-- Confirmed empirically that gz-sensors8's NavSat sensor applies
                     position_sensing/horizontal's noise stddev directly in degrees,
                     not meters, despite the SDF spec documenting units of meters -
                     a stddev of 0.5 (intended as 0.5m) produced gps/fix readings
                     30-50km from the configured world origin; dropping to 1e-6
                     landed within about 1m (matching the robot spawn offset),
                     confirming the unit mismatch. horizontal stddev below (4.5e-8
                     deg) is a degrees-converted equivalent of about 5mm (0.005m
                     divided by about 111320 m per deg) - dropped from an earlier
                     ~0.5m (uncorrected-consumer-GPS-grade) after that noise level
                     made rviz_satellite's AerialMap display (anchored to /gps/fix,
                     see rviz_outdoor.rviz) visibly jitter every fix update (10Hz),
                     even while the robot was stationary - the map tiles were
                     re-centering on each noisy sample. Tradeoff - this is now closer
                     to corrected/RTK-grade horizontal accuracy than realistic
                     uncorrected GPS - accepted for now for a stable map display over
                     GPS-noise realism, since GPSFactor's own correction behavior
                     (LIO-SAM/mapOptmization.cpp) isn't the focus of this simulation.
                     vertical noise (altitude channel) is not affected by this bug
                     and stays in real meters, 1.5m stddev, since real GPS vertical
                     is typically 2-3x worse than horizontal and altitude doesn't
                     drive AerialMap's rendering. -->
                <position_sensing>
                    <horizontal><noise type="gaussian"><mean>0</mean><stddev>0.000000045</stddev></noise></horizontal>
                    <vertical><noise type="gaussian"><mean>0</mean><stddev>1.5</stddev></noise></vertical>
                </position_sensing>
            </navsat>
        </sensor>
    </gazebo>

</robot>
